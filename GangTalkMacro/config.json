  "allow_ocr_fallback": true,
  "debug": true,
  "smoke_test": false,

  "auto_bring_to_front": true,
  "auto_arrange_windows": true,
  "arrange": { "cols": 5, "margin": 6, "height_ratio": 0.88 },

  "kakao": {
    "process_name": "KakaoTalk.exe",
    "exclude_titles": [
